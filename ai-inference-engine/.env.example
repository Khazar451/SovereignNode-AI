# SovereignNode AI — Environment variable overrides for config.py
# Copy to .env and adjust values. All fields are optional.
# Load with: python-dotenv or export manually before running.

# --- Ollama (LLM backend) ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:3b

# --- Paths ---
# MANUALS_DIR=./manuals
# CHROMA_PERSIST_DIR=./chroma_store
# LLM_CACHE_DIR=./model_cache

# --- Embedding ---
# EMBEDDING_MODEL_NAME=sentence-transformers/all-mpnet-base-v2
# EMBEDDING_DEVICE=cpu
# EMBEDDING_BATCH_SIZE=16

# --- Generation ---
# MAX_NEW_TOKENS=512
# TEMPERATURE=0.15
# TOP_P=0.9
# REPETITION_PENALTY=1.1

# --- RAG Retrieval (tuned for ≥80% confidence) ---
# TOP_K_RESULTS=5
# SIMILARITY_THRESHOLD=0.25

# --- Chunking ---
# CHUNK_SIZE=384
# CHUNK_OVERLAP=96

# --- Logging ---
# LOG_LEVEL=INFO

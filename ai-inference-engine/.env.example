# SovereignNode AI — Environment variable overrides for config.py
# Copy to .env and adjust values. All fields are optional.
# Load with: python-dotenv or export manually before running.

# --- Paths ---
# MANUALS_DIR=./manuals
# CHROMA_PERSIST_DIR=./chroma_store
# LLM_CACHE_DIR=./model_cache

# --- Embedding ---
# EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_DEVICE=cuda
# EMBEDDING_BATCH_SIZE=64

# --- Language Model ---
# LLM_MODEL_ID=microsoft/Phi-3-mini-4k-instruct
# LLM_DEVICE_MAP=auto
# LLM_LOAD_IN_4BIT=true
# LLM_BNB_COMPUTE_DTYPE=bfloat16
# LLM_USE_FLASH_ATTENTION=true

# --- Generation ---
# MAX_NEW_TOKENS=512
# TEMPERATURE=0.1
# TOP_P=0.9
# REPETITION_PENALTY=1.1

# --- RAG Retrieval ---
# TOP_K_RESULTS=3
# SIMILARITY_THRESHOLD=0.0

# --- Chunking ---
# CHUNK_SIZE=512
# CHUNK_OVERLAP=64

# --- Logging ---
# LOG_LEVEL=INFO
